{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "CMake Configure and Build",
			"type": "shell",
			"command": "cmake",
			"args": [
				"--preset",
				"windows-2022"
			],
			"isBackground": false,
			"problemMatcher": [],
			"group": "build"
		},
		{
			"label": "Build bsplugins Release",
			"type": "shell",
			"command": "cmake",
			"args": [
				"--build",
				"vsbuild",
				"--config",
				"Release",
				"--target",
				"bsplugins"
			],
			"isBackground": false,
			"group": "build"
		}
	]
}